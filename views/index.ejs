<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Live Tracker</title>

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Leaflet CSS -->
  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />

  <!-- Routing CSS -->
  <link rel="stylesheet"
    href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css" />

  <style>
    html, body {
      margin: 0;
      height: 100%;
    }

    #map {
      height: 100vh;
      width: 100vw;
      z-index: 1;
    }

    /* ☰ Button */
    .panel-toggle {
      position: absolute;
      top: 10px;
      left: 10px;
      z-index: 2100;
      background: #007bff;
      color: white;
      padding: 10px;
      border-radius: 5px;
      cursor: pointer;
    }

    /* Panel */
    .side-panel {
      position: absolute;
      top: 0;
      left: -260px;
      width: 250px;
      height: 100%;
      background: white;
      z-index: 2000;
      padding: 15px;
      transition: left 0.3s ease;
    }

    .side-panel.open {
      left: 0;
    }

    .side-panel input,
    .side-panel button,
    .side-panel select {
      width: 100%;
      margin-bottom: 10px;
      padding: 8px;
    }

    /* 🌙 DARK MODE */
    body.dark {
      background: #121212;
      color: white;
    }

    body.dark #sidePanel {
      background: #1e1e1e;
    }

    body.dark button {
      background: #333;
      color: white;
    }

    /* Zoom buttons */
    .leaflet-control-zoom a {
      width: 50px !important;
      height: 50px !important;
      line-height: 50px !important;
      font-size: 22px !important;
      border-radius: 10px !important;
    }

    .leaflet-control-zoom {
      position: absolute !important;
      right: 10px !important;
      bottom: 120px !important;
      z-index: 1000;
    }
  </style>
</head>

<body>

<div class="panel-toggle" onclick="togglePanel()">☰</div>

<div class="side-panel" id="sidePanel">
  <h3>Tracker</h3>

  <input id="nameInput" placeholder="Your Name">
  <input id="roomInput" placeholder="Room Code">

  <button onclick="joinRoom()">Join Room</button>

  <select id="userList" onchange="followUser(this.value)">
    <option value="">Follow User</option>
  </select>

  <button onclick="enableFollow()">Follow Me</button>

  <!-- 🌙 THEME BUTTON -->
  <button onclick="toggleTheme()">🌙 Toggle Theme</button>
</div>

<div id="map"></div>

<!-- Scripts -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script src="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.js"></script>
<script src="/socket.io/socket.io.js"></script>

<script>
const socket = io();

// 🌗 THEME
let isDark = localStorage.getItem("theme") === "dark";

// ✅ MAP
const map = L.map("map", {
  zoomControl: false
}).setView([28.9845, 77.7064], 13);

L.control.zoom({ position: "bottomright" }).addTo(map);

// 🌍 TILE LAYERS
const lightLayer = L.tileLayer(
  "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"
);

const darkLayer = L.tileLayer(
  "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png"
);

// APPLY THEME
if (isDark) {
  darkLayer.addTo(map);
  document.body.classList.add("dark");
} else {
  lightLayer.addTo(map);
}

// 🌙 TOGGLE
function toggleTheme() {
  isDark = !isDark;

  if (isDark) {
    map.removeLayer(lightLayer);
    darkLayer.addTo(map);
    document.body.classList.add("dark");
    localStorage.setItem("theme", "dark");
  } else {
    map.removeLayer(darkLayer);
    lightLayer.addTo(map);
    document.body.classList.remove("dark");
    localStorage.setItem("theme", "light");
  }
}

// PANEL
function togglePanel() {
  document.getElementById("sidePanel").classList.toggle("open");
}

let markers = {};
let myLocation = null;
let roomId = null;
let username = "";

// JOIN ROOM
function joinRoom() {
  roomId = document.getElementById("roomInput").value;
  username = document.getElementById("nameInput").value;

  socket.emit("join-room", { roomId, username });
}

// RECEIVE LOCATION
socket.on("receive-location", ({ lat, lng, id, username: otherUser }) => {
  if (markers[id]) {
    markers[id].setLatLng([lat, lng]);
  } else {
    markers[id] = L.marker([lat, lng])
      .addTo(map)
      .bindTooltip(otherUser || "User", { permanent: true, direction: "top" });
  }
});

// REMOVE ON DISCONNECT
socket.on("user-disconnected", (id) => {
  if (markers[id]) {
    map.removeLayer(markers[id]);
    delete markers[id];
  }
});

// GEOLOCATION
navigator.geolocation.watchPosition((pos) => {
  const { latitude, longitude } = pos.coords;

  myLocation = { lat: latitude, lng: longitude };

  map.panTo([latitude, longitude]);

  if (roomId) {
    // FIXED: Added roomId to the payload so server can route it
    socket.emit("send-location", { ...myLocation, roomId });
  }
}, (err) => console.log(err), {
  enableHighAccuracy: true,
  timeout: 5000,
  maximumAge: 0
});
</script>

</body>
</html>
