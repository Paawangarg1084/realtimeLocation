<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Live Tracker</title>

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />

  <link rel="stylesheet"
    href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css" />

  <style>
    html, body {
      margin: 0;
      height: 100%;
    }

    #map {
      height: 100vh;
      width: 100vw;
      z-index: 1;
    }

    /* 🔥 Zoom button fix */
    .leaflet-control-zoom {
      margin-bottom: 60px !important;
    }

    /* ☰ Button */
    .panel-toggle {
      position: absolute;
      top: 10px;
      left: 10px;
      z-index: 2100;
      background: #007bff;
      color: white;
      padding: 10px;
      border-radius: 5px;
      cursor: pointer;
    }

    /* Panel */
    .side-panel {
      position: absolute;
      top: 0;
      left: -260px;
      width: 250px;
      height: 100%;
      background: white;
      z-index: 2000;
      padding: 15px;
      transition: left 0.3s ease;
      touch-action: auto;
    }

    .side-panel.open {
      left: 0;
    }

    .side-panel input,
    .side-panel button,
    .side-panel select {
      width: 100%;
      margin-bottom: 10px;
      padding: 8px;
      pointer-events: auto;
    }

    /* 🔥 Mobile touch fix */
    .leaflet-container {
      touch-action: pan-x pan-y;
    }

    /* 🔥 Bigger zoom buttons */
     /* 🔥 Bigger zoom buttons */
.leaflet-control-zoom a {
  width: 50px !important;
  height: 50px !important;
  line-height: 50px !important;
  font-size: 22px !important;
   border-radius: 10px !important;
}

/* 🔥 Move to middle-right */
.leaflet-control-zoom {
  position: absolute !important;
  right: 10px !important;
  bottom: 120px !important; /* 👈 upar shift */
  z-index: 1000;
}
  </style>
</head>

<body>

<div class="panel-toggle" onclick="togglePanel()">☰</div>

<div class="side-panel" id="sidePanel">
  <h3>Tracker</h3>

  <input id="nameInput" placeholder="Your Name">
  <input id="roomInput" placeholder="Room Code">

  <button onclick="joinRoom()">Join Room</button>

  <select id="userList" onchange="followUser(this.value)">
    <option value="">Follow User</option>
  </select>

  <button onclick="enableFollow()">Follow Me</button>
</div>

<div id="map"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script src="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.js"></script>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/script.js"></script>

</body>
</html>