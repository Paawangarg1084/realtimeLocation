<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Live Tracker</title>

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />

  <link rel="stylesheet"
    href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css" />

  <style>
    html, body {
      margin: 0;
      height: 100%;
    }

    /* 🌗 THEME VARIABLES */
    :root {
      --bg: #ffffff;
      --text: #000000;
      --panel: #ffffff;
    }

    .dark {
      --bg: #121212;
      --text: #ffffff;
      --panel: #1e1e1e;
    }

    body {
      background: var(--bg);
      color: var(--text);
      transition: 0.3s;
    }

    #map {
      height: 100vh;
      width: 100vw;
      z-index: 1;
    }

    /* 🔥 Zoom button fix */
    .leaflet-control-zoom {
      margin-bottom: 60px !important;
    }

    /* ☰ Button */
    .panel-toggle {
      position: absolute;
      top: 10px;
      left: 10px;
      z-index: 2100;
      background: #007bff;
      color: white;
      padding: 10px;
      border-radius: 5px;
      cursor: pointer;
    }

    /* Panel */
    .side-panel {
      position: absolute;
      top: 0;
      left: -260px;
      width: 250px;
      height: 100%;
      background: var(--panel);
      z-index: 2000;
      padding: 15px;
      transition: left 0.3s ease;
      display: flex;
      flex-direction: column;
    }

    .side-panel.open {
      left: 0;
    }

    .side-panel input,
    .side-panel button,
    .side-panel select {
      width: 100%;
      margin-bottom: 10px;
      padding: 8px;
    }

    /* 🔥 Mobile touch fix */
    .leaflet-container {
      touch-action: pan-x pan-y;
    }

    /* 🔥 Bigger zoom buttons */
    .leaflet-control-zoom a {
      width: 50px !important;
      height: 50px !important;
      line-height: 50px !important;
      font-size: 22px !important;
      border-radius: 10px !important;
    }

    /* 🔥 Move zoom buttons */
    .leaflet-control-zoom {
      position: absolute !important;
      right: 10px !important;
      bottom: 120px !important;
      z-index: 1000;
    }

    /* 🌗 Toggle container */
    .theme-toggle-container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 10px;
      padding: 10px;
      border-radius: 10px;
    }

    /* 🌗 Toggle switch */
    .theme-switch {
      position: relative;
      display: inline-block;
      width: 50px;
      height: 25px;
    }

    .theme-switch input {
      display: none;
    }

    .slider {
      position: absolute;
      cursor: pointer;
      background-color: #ccc;
      border-radius: 25px;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      transition: 0.3s;
    }

    .slider::before {
      content: "";
      position: absolute;
      height: 20px;
      width: 20px;
      left: 3px;
      bottom: 2.5px;
      background-color: white;
      border-radius: 50%;
      transition: 0.3s;
    }

    input:checked + .slider {
      background-color: #4caf50;
    }

    input:checked + .slider::before {
      transform: translateX(25px);
    }
  </style>
</head>

<body>

<div class="panel-toggle" onclick="togglePanel()">☰</div>

<div class="side-panel" id="sidePanel">
  <h3>Tracker</h3>

  <input id="nameInput" placeholder="Your Name">
  <input id="roomInput" placeholder="Room Code">

  <button onclick="joinRoom()">Join Room</button>

  <select id="userList" onchange="followUser(this.value)">
    <option value="">Follow User</option>
  </select>

  <button onclick="enableFollow()">Follow Me</button>

  <!-- ✅ TOGGLE INSIDE PANEL (FIXED) -->
  <div class="theme-toggle-container">
    <span>Dark Mode</span>

    <label class="theme-switch">
      <input type="checkbox" id="themeToggle">
      <span class="slider"></span>
    </label>
  </div>

</div>

<div id="map"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script src="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.js"></script>
<script src="/socket.io/socket.io.js"></script>

<script>
  function togglePanel() {
    document.getElementById("sidePanel").classList.toggle("open");
  }

  const toggle = document.getElementById("themeToggle");

  toggle.addEventListener("change", () => {
    const isDark = toggle.checked;

    document.body.classList.toggle("dark", isDark);
    localStorage.setItem("theme", isDark ? "dark" : "light");

    if (typeof updateMapTheme === "function") {
      updateMapTheme(isDark);
    }
  });

  window.onload = () => {
    const savedTheme = localStorage.getItem("theme");

    if (savedTheme === "dark") {
      document.body.classList.add("dark");
      document.getElementById("themeToggle").checked = true;

      if (typeof updateMapTheme === "function") {
        updateMapTheme(true);
      }
    }
  };
</script>

<script src="/js/script.js"></script>

</body>
</html>