<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Live Tracker</title>

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- ✅ LEAFLET CSS -->
  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />

  <!-- ✅ ROUTING CSS -->
  <link rel="stylesheet"
    href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css" />

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      transition: background 0.3s ease;
    }

    #map {
      height: 100vh;
      width: 100%;
    }

    .panel-toggle {
      position: absolute;
      top: 15px;
      left: 15px;
      z-index: 2000;
      background: #007bff;
      color: white;
      padding: 10px;
      border-radius: 5px;
      cursor: pointer;
    }

    .side-panel {
      position: absolute;
      top: 0;
      left: -260px;
      width: 250px;
      height: 100%;
      background: white;
      z-index: 1500;
      padding: 15px;
      transition: left 0.3s ease;
    }

    .side-panel.open { left: 0; }

    .side-panel input,
    .side-panel button,
    .side-panel select {
      width: 100%;
      margin-bottom: 10px;
      padding: 8px;
    }

    /* 🌙 DARK MODE */
    body.dark {
      background: #121212;
      color: white;
    }

    body.dark .side-panel {
      background: #1e1e1e;
    }

    body.dark input,
    body.dark select {
      background: #333;
      color: white;
      border: 1px solid #555;
    }

    body.dark button {
      background: #444;
      color: white;
    }

    .theme-wrap {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 15px;
    }
  </style>
</head>

<body>

<div class="panel-toggle" onclick="togglePanel()">☰</div>

<div class="side-panel" id="sidePanel">
  <h3>Tracker</h3>

  <!-- 🌙 DARK MODE TOGGLE -->
  <div class="theme-wrap">
    <input type="checkbox" id="themeToggle">
    <label for="themeToggle">Dark Mode</label>
  </div>

  <input id="nameInput" placeholder="Your Name">
  <input id="roomInput" placeholder="Room Code">

  <button onclick="joinRoom()">Join Room</button>

  <select id="userList" onchange="followUser(this.value)">
    <option value="">Follow User</option>
  </select>

  <button onclick="enableFollow()">Follow Me</button>
</div>

<div id="map"></div>

<script>
  function togglePanel() {
    document.getElementById("sidePanel").classList.toggle("open");
  }

  /* ✅ APPLY SAVED THEME ON LOAD */
  (function () {
    const savedTheme = localStorage.getItem("theme");
    if (savedTheme === "dark") {
      document.body.classList.add("dark");
      const toggle = document.getElementById("themeToggle");
      if (toggle) toggle.checked = true;
    }
  })();
</script>

<!-- ✅ JS FILES -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script src="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.js"></script>
<script src="/socket.io/socket.io.js"></script>

<!-- 🔥 YOUR MAIN SCRIPT -->
<script src="/js/script.js"></script>

</body>
</html>