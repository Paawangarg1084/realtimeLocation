<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Live Tracker</title>

  <!-- FIXED: Actual Leaflet CSS URL -->
  <link rel="stylesheet" href="https://cloudflare.com" />
  <!-- FIXED: Actual Routing Machine CSS URL -->
  <link rel="stylesheet" href="https://unpkg.com" />

  <style>
    /* RESET & FIX MARKER VISIBILITY */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { width: 100%; height: 100%; overflow: hidden; }
    
    /* Important for marker display */
    .leaflet-marker-icon { box-sizing: content-box !important; }

    #map { height: 100vh; width: 100%; background: #eee; }

    .panel-toggle {
      position: absolute; top: 15px; left: 15px; z-index: 2000;
      background: #007bff; color: white; padding: 10px;
      border-radius: 5px; cursor: pointer;
    }

    .side-panel {
      position: absolute; top: 0; left: -260px; width: 250px;
      height: 100%; background: white; z-index: 1500;
      padding: 15px; transition: left 0.3s ease;
      box-shadow: 2px 0 5px rgba(0,0,0,0.1);
    }

    .side-panel.open { left: 0; }

    .side-panel input, .side-panel button, .side-panel select {
      width: 100%; margin-bottom: 10px; padding: 8px;
    }

    /* DARK MODE STYLES */
    body.dark .side-panel { background: #333; color: white; }
    body.dark .side-panel input { background: #444; color: white; border: 1px solid #555; }
    .theme-wrap { margin-bottom: 15px; display: flex; align-items: center; gap: 10px; }
  </style>
</head>

<body>

<div class="panel-toggle" onclick="togglePanel()">☰</div>

<div class="side-panel" id="sidePanel">
  <h3>Tracker</h3>

  <div class="theme-wrap">
    <input type="checkbox" id="themeToggle">
    <label for="themeToggle">Dark Mode</label>
  </div>

  <input id="nameInput" placeholder="Your Name">
  <input id="roomInput" placeholder="Room Code">

  <button onclick="joinRoom()">Join Room</button>

  <select id="userList" onchange="followUser(this.value)">
    <option value="">Follow User</option>
  </select>

  <button onclick="enableFollow()">Follow Me</button>
</div>

<div id="map"></div>

<script>
  function togglePanel() {
    document.getElementById("sidePanel").classList.toggle("open");
  }
</script>

<!-- FIXED: Actual Leaflet and Routing JS URLs -->
<script src="https://cloudflare.com"></script>
<script src="https://unpkg.com"></script>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/script.js"></script>

</body>
</html>
